WAP to read array of 10 interger and count total no of even and odd
#include<stdio.h>
int main()
{
int arr[10];
int even=0,odd=0;
printf("enter the elements");
for(int i=0;i<10;i++)
{
scanf("%d",&arr[i]);
if(arr[i]%2==0)
even++;
else
odd++;
}
printf("even number=%d\n",even);
printf("odd number=%d\n",odd);
return 0;
}

WAP to read two array of size 5 and store sum of these arrays into third array
#include<stdio.h>

int main()
{
    int a[5], b[5], c[5];

    printf("Enter the first elements:\n");
    for(int i = 0; i < 5; i++)
        scanf("%d", &a[i]);

    printf("Enter the second elements:\n");
    for(int i = 0; i < 5; i++)
        scanf("%d", &b[i]);

    for(int i = 0; i < 5; i++)
    {
        c[i] = a[i] + b[i];
        printf("Sum[%d] = %d\n", i, c[i]);
    }

    return 0;
}

Maximum Element
#include<stdio.h>
int main() {
    int a[5], max;

    for(int i=0;i<5;i++)
        scanf("%d",&a[i]);

    max = a[0];
    for(int i=1;i<5;i++)
        if(a[i] > max)
            max = a[i];

    printf("Max = %d", max);
    return 0;
}

