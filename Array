Reverse Array
#include<stdio.h>
int main() {
    int a[5];

    for(int i=0;i<5;i++)
        scanf("%d",&a[i]);

    for(int i=4;i>=0;i--)
        printf("%d ", a[i]);

    return 0;
}

Linear Search
#include<stdio.h>
int main()
{
int a[5],key,found=0;
printf("enter the element");
for(int i=0;i<5;i++)
{
scanf("%d",&a[i]);
}
printf("enter the key");
scanf("%d",&key);
for(int i=0;i<5;i++)
{
if(a[i]==key)
            found=1;

    if(found)
        printf("Found");
    else
        printf("Not Found");

    return 0;
}
}

