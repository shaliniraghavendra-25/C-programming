Q6.Reverse a Number using Function
#include<stdio.h>
void reverse()
{
int rev,s=0;
while(num!=0)
{
rev=num%10;
s=s*10+rev;
num=num/10;
}
return rev;
}
int main()
{
int num;
printf("enter the number:");
scanf("%d",&num);
printf("Reverse = %d\n", reverse(num));
return 0;
}

Q7.Palindrome Number using Function
#include<stdio.h>
void ispalindrome()
{
int rev,s=0,p;
while(num!=0)
{
rev=num%10;
s=s*10+rev;
num=num/10;
p=num;
}
return rev;
}
if(p==rev)
return 1;
else
return 0;
int main()
{
int num;
printf("enter the number:");
scanf("%d",&num);
if(ispalindrome(num))
printf("Palindrome\n");
else
printf("Not Palindrome\n");
return 0;
}

